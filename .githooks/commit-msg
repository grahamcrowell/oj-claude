#!/usr/bin/env bash
#
# commit-msg hook — enforce a Regen-Source trailer when staged files
# intersect plugin-tree.snapshot.yaml's tracked set.
#
# RATIONALE
#   The oj-claude plugin tree is regenerated by `juntogen/claude/generate`.
#   Hand edits to files under that regenerated scope silently diverge from
#   the generator's output and surface only when the next regen wipes the
#   change. This hook makes the divergence audit-visible: a commit that
#   touches snapshot-tracked files must declare its provenance via a
#   trailer of the form:
#
#       Regen-Source: juntogen@<7-40 hex chars>
#
#   - Generator-emitted commits include the trailer automatically.
#   - Human edits land the trailer explicitly (intent-forcing, not crypto).
#   - --no-verify bypasses leave the commit body trailer-less — visible
#     to anyone reading `git log` as a deliberate override.
#
# FAIL-OPEN SEMANTICS (BL-025-m.5 SRE constraint)
#   This hook MUST NOT block on its own runtime errors. Every failure
#   path other than a real audit violation emits a WARNING line to
#   stderr and exits 0. The audit trail still surfaces the bypass via
#   the absent trailer in `git log`.
#
# BYPASS DESIGN (BL-025-m.5 DE constraint)
#   Trailer-bearing commit message is the canonical bypass. `--no-verify`
#   is the operator override and remains supported (and visible).
#
# INSTALL
#   Run `oj-helper install-hooks` in the repo root. This sets
#   `git config core.hooksPath .githooks`. The hook is OPT-IN per the
#   PM constraint (no auto-install on plugin install).
#
# PERFORMANCE
#   Budget: well under 500ms on a clean repo. Uses no external
#   processes beyond core POSIX utilities (grep, sed, sort, comm).

set -uo pipefail

# Fast path: no commit message file (defensive — should always be present).
msg_file="${1:-}"
[ -z "${msg_file}" ] && exit 0
[ ! -f "${msg_file}" ] && exit 0

# Fast path: no staged files (defensive — commit-msg runs after pre-commit
# so staging is normally settled).
staged_files=$(git diff --cached --name-only 2>/dev/null) || exit 0
[ -z "${staged_files}" ] && exit 0

# Locate the snapshot YAML. The snapshot lives in the juntogen sibling
# repo by convention:
#   <parent-of-oj-claude>/juntogen/claude/validation/snapshots/plugin-tree.snapshot.yaml
# A non-canonical layout (e.g., adopter who cloned only oj-claude) is
# normal — fail-open with a stderr WARNING.
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd "${script_dir}/.." && pwd)"
parent_dir="$(dirname "${repo_root}")"
snapshot_yaml="${parent_dir}/juntogen/claude/validation/snapshots/plugin-tree.snapshot.yaml"

if [ ! -f "${snapshot_yaml}" ]; then
  echo "WARNING: snapshot-drift check skipped — juntogen sibling not found at ${snapshot_yaml}" >&2
  exit 0
fi

if [ ! -r "${snapshot_yaml}" ]; then
  echo "WARNING: snapshot-drift check skipped — ${snapshot_yaml} not readable" >&2
  exit 0
fi

# Parse the tracked-files set out of the YAML. The structure is:
#   files:
#     - "path/one"
#     - "path/two"
#   plugin_json_keys:        # sibling list — MUST be excluded
#     - "name"
#     - "version"
#     ...
# We use awk (no yq dependency) anchored to the `files:` block: parsing
# starts on the line AFTER `^files:` and stops at the next line that
# begins with a non-whitespace character (the next top-level key, which
# in this snapshot is `plugin_json_keys:`). Inside that window, only
# lines of the form `  - "<path>"` are emitted. sed then strips the
# `  - "` prefix and trailing `"`. This avoids the over-match where a
# bare grep on the `  - "x"` indent shape would also catch string-list
# entries under sibling keys (plugin_json_keys, command_paths,
# skill_frontmatter_required, etc.), which would cause fail-CLOSED
# false-positives when an adopter stages a top-level file whose name
# matches one of those values (e.g., `name`, `version`, `license`).
#
# Pure POSIX awk + sed; no yq, no Python. Robust to comments between
# the `files:` header and the first list item (awk `flag` stays set;
# the `/  - "/` guard filters non-list lines).
tracked=""
if ! tracked=$(awk '/^files:/{flag=1; next} /^[^[:space:]]/{flag=0} flag && /^[[:space:]]+-[[:space:]]+"/{print}' "${snapshot_yaml}" 2>/dev/null \
                 | sed -E 's/^[[:space:]]+-[[:space:]]+"([^"]+)".*$/\1/'); then
  echo "WARNING: snapshot-drift check skipped — could not parse ${snapshot_yaml}" >&2
  exit 0
fi

if [ -z "${tracked}" ]; then
  echo "WARNING: snapshot-drift check skipped — no files: entries parsed from ${snapshot_yaml}" >&2
  exit 0
fi

# Intersect staged_files with tracked. Both lists are sorted before
# `comm -12` (POSIX-required). `comm -12` prints lines present in both.
# LC_ALL=C is REQUIRED — macOS comm under a UTF-8 locale collates
# strings with embedded `/` and `.` inconsistently, producing empty
# intersections for paths that visibly match. Forcing the C locale
# keeps comparison byte-wise and deterministic across platforms.
staged_tracked=$(LC_ALL=C comm -12 \
  <(echo "${staged_files}" | LC_ALL=C sort -u) \
  <(echo "${tracked}"      | LC_ALL=C sort -u))

# No snapshot-tracked files staged — out of scope, pass.
[ -z "${staged_tracked}" ] && exit 0

# Snapshot-tracked files are staged. Require the trailer.
# Accepted form: `Regen-Source: juntogen@<7-40 hex>` on its own line.
# Trailing whitespace is tolerated. The trailer must be in the commit
# message body — anywhere is fine; `git log --format=%B` will surface it.
if grep -qE '^Regen-Source:[[:space:]]+juntogen@[0-9a-f]{7,40}[[:space:]]*$' "${msg_file}"; then
  exit 0
fi

# Block. Emit diagnostic with the offending file list and trailer guidance.
{
  echo "ERROR: Commit touches plugin-tree.snapshot.yaml tracked files:"
  echo "${staged_tracked}" | sed 's/^/  /'
  echo
  echo "Add a Regen-Source trailer to the commit message:"
  echo "  Regen-Source: juntogen@<7-40 hex sha>"
  echo
  echo "If editing intentionally as a human, run the juntogen pipeline"
  echo "instead and copy the resulting commit SHA from juntogen. Or"
  echo "override with --no-verify (audit will surface this)."
} >&2
exit 1
